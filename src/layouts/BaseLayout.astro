---
const { title, description } = Astro.props;
import '../styles/global.css';
---
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />                                                              
    <meta name="description" content={description} /> 
    <title>{title}</title>
  </head>
  <body>
    <div class="container">
      <slot />
    </div>
  </body>
</html>